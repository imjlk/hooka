#!/bin/sh
set -eu

log_file="${HOOKA_TEST_WRANGLER_LOG:-/data/mock-wrangler.log}"
mkdir -p "$(dirname "$log_file")"

printf 'wrangler %s\n' "$*" >> "$log_file"

if [ -n "${HOOKA_TEST_WRANGLER_STDOUT:-}" ]; then
  printf '%s\n' "$HOOKA_TEST_WRANGLER_STDOUT"
fi

if [ -n "${HOOKA_TEST_WRANGLER_STDERR:-}" ]; then
  printf '%s\n' "$HOOKA_TEST_WRANGLER_STDERR" >&2
fi

exit "${HOOKA_TEST_WRANGLER_EXIT_CODE:-0}"
