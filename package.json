{
  "name": "hooka",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun --filter='./packages/*' run build",
    "build:apps": "bun --filter='./apps/*' run build",
    "check": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "dev:server": "bun --hot apps/server/src/index.ts",
    "dev:worker": "bun --hot apps/worker/src/index.ts",
    "dev:ui": "bun --hot packages/admin-ui/src/dev.ts",
    "dev:cli": "bun --filter @hooka/cli run dev",
    "test": "bun test",
    "test:dev-ui:smoke": "bun run scripts/smoke-dev-ui.ts",
    "test:e2e:docker": "bun run scripts/e2e/dockerized-preset-e2e.ts",
    "task:validate": "bun run apps/cli/src/index.ts task validate",
    "bake:generate": "bun run scripts/generate-docker-bake.ts",
    "image:install-features": "bun run apps/cli/src/index.ts image install-features"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
