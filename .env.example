HOOKA_DB_PATH=.hooka/hooka.sqlite
HOOKA_MANIFEST_PATH=.hooka/installed-capabilities.json
HOOKA_TARGETS_PATH=.hooka/targets.json
HOOKA_WEBHOOK_SECRET=local-secret
HOOKA_ADMIN_TOKEN=local-admin-token
HOOKA_INSTALLED_CAPABILITIES=wrangler
HOOKA_PORT=3000
HOOKA_POLL_INTERVAL_MS=2000
HOOKA_RUN_LEASE_MS=900000
HOOKA_RUN_MAX_ATTEMPTS=3
HOOKA_RETRY_BASE_DELAY_MS=5000
HOOKA_WORKER_HEARTBEAT_MS=10000
HOOKA_UI_PORT=4310
HOOKA_UI_API_ORIGIN=http://127.0.0.1:3000
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
